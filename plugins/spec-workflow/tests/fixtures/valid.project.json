{
    "schemaVersion": 1,
    "project": {
        "name": "fixture-project",
        "description": "hermetic test fixture",
        "mainBranch": "main",
        "branchPattern": "fx/<id>-<slug>"
    },
    "boards": [
        {
            "id": "main",
            "provider": "github-project",
            "owner": "fixture-owner",
            "repo": "fixture-owner/fixture-project",
            "projectNumber": 1,
            "projectId": "PVT_fixture0000000",
            "fields": {
                "status": {
                    "fieldId": "PVTSSF_fixtureStatus0",
                    "options": {
                        "Backlog": "aaaa0001",
                        "In progress": "aaaa0002",
                        "In review": "aaaa0003",
                        "QA": "aaaa0004",
                        "Ready": "aaaa0005",
                        "Deployed": "aaaa0006"
                    }
                },
                "priority": {
                    "fieldId": "PVTSSF_fixturePrio00",
                    "options": { "P0": "bbbb0001", "P1": "bbbb0002", "P2": "bbbb0003" }
                },
                "estimate": { "fieldId": "PVTF_fixtureEst000" }
            },
            "statusFlow": ["Backlog", "In progress", "In review", "QA", "Ready", "Deployed"],
            "labels": { "bug": "type:bug", "feature": "type:feature" }
        }
    ],
    "specs": [
        {
            "id": "core",
            "title": "Core fixture spec",
            "board": "main",
            "specPath": "SPEC.md",
            "backlogPath": "docs/BACKLOG.md",
            "taskPrefix": "FX",
            "epics": [
                { "id": "EI", "title": "Infra", "taskRanges": [[90, 99]] },
                { "id": "E0", "title": "Foundations", "taskRanges": [[1, 9]] },
                {
                    "id": "E1",
                    "title": "Features",
                    "taskRanges": [[10, 19]],
                    "blockedBy": [{ "epic": "E0", "untilStatus": "Deployed" }]
                },
                { "id": "E9", "title": "Zero-seed", "taskRanges": [[80, 89]] },
                {
                    "id": "E2",
                    "title": "Downstream",
                    "taskRanges": [[20, 29]],
                    "blockedBy": [{ "epic": "E9", "untilStatus": "Deployed" }]
                }
            ],
            "invariants": ["Fixture invariant: never violate the fixture."]
        }
    ],
    "commands": { "gate": "true", "test": "true" },
    "delegation": { "devModel": "sonnet", "reviewModel": "sonnet" },
    "paths": { "handoffDir": "docs/handoffs", "checkpointFile": ".claude/CHECKPOINT" },
    "methodology": { "tdd": true, "isolationSuite": "", "maxInProgress": 1 }
}
